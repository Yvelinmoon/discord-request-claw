# ── Discord ────────────────────────────────────
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here          # 必填：Bot 只响应此服务器的用户
DISCORD_STAFF_CHANNEL_ID=your_channel_id_here  # 选填：不填则跳过管理员通知

# ── 选填 ──────────────────────────────────────
DISCORD_VERIFIED_ROLE_ID=0                    # 0 = 不启用自动赋予角色
DISCORD_NOTIFY_ROLE_ID=0                      # 0 = 不 @任何人

# ── 飞书 ───────────────────────────────────────
# 在 https://open.feishu.cn/app 创建自建应用后获取
FEISHU_APP_ID=your_feishu_app_id_here
FEISHU_APP_SECRET=your_feishu_app_secret_here
